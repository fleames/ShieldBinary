# ShieldBinary — optional env vars (override config.yaml)
# Prefix: SHIELD_ for most; some use PORT.

# Server
# PORT=8080

# Redis (required for job queue)
# SHIELD_REDIS_ADDR=localhost:6379
# SHIELD_REDIS_PASSWORD=
# SHIELD_REDIS_DB=0

# S3-compatible storage (Hetzner, MinIO, etc.) — omit for local ./storage
# SHIELD_STORAGE_ENDPOINT=https://fsn1.your-objectstorage.com
# SHIELD_STORAGE_BUCKET=shieldbinary
# SHIELD_STORAGE_ACCESS_KEY=
# SHIELD_STORAGE_SECRET_KEY=

# Auth (required for production — enables registration/login)
# SHIELD_JWT_SECRET=change-me-in-production
# SHIELD_DATABASE_PATH=./shieldbinary.db

# Paths (optional — auto-detected if empty)
# SHIELD_ENGINE_PATH=bin/engine/shieldbinary-engine
# SHIELD_NATIVE_LOADER_PATH=bin/loader.exe

# CORS (optional — empty = same-origin only; "*" = allow all)
# SHIELD_CORS_ORIGINS=*
